# OpenRouter API Key
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# ── GenLayer Onchain Configuration ──
# Leave unset to run in Mock Bridge mode (no blockchain needed)

# Deploy Orbitjob.py via GenLayer Studio, then paste the address:
# GENLAYER_CONTRACT_ADDRESS=0x...

# Network: localnet | bradbury | testnet | mainnet
# Defaults to localnet if unset
# GENLAYER_NETWORK=bradbury

# RPC URL (optional — auto-resolves for known networks)
# For Bradbury: https://bradbury.genlayer.net
# For localnet: http://127.0.0.1:8545
# GENLAYER_RPC_URL=https://bradbury.genlayer.net

# Private key for write transactions
# You can export this from GenLayer Studio
# GENLAYER_PRIVATE_KEY=your_private_key_hex

# Account address (alternative to PRIVATE_KEY for read-only)
# GENLAYER_ACCOUNT_ADDRESS=0x...

# Set to "real" to enable live onchain mode
# GENLAYER_MODE=real

# ── Server ──
PORT=5005
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_MAX=200
