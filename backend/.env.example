# ── Required Variables ──
PORT=5005
GENLAYER_CONTRACT_ADDRESS=0x4736F12d6E113ed580d863351f09CBeAd72dca2A
GENLAYER_NETWORK=localnet
GENLAYER_MODE=real
OPENROUTER_API_KEY=sk-or-v1-your_key_here
FRONTEND_ORIGIN=http://localhost:5173

# ── Authentication (optional — sessions use Redis/in-memory) ──
# JWT_SECRET=your_jwt_secret_phrase_at_least_32_characters

# ── Redis (optional — falls back to in-memory) ──
# REDIS_URL=redis://:password@localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ── Rate Limiting (optional) ──
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=200

# ── Logging (optional) ──
# LOG_LEVEL=info

# ── Optional: GenLayer Write Access ──
# GENLAYER_PRIVATE_KEY=your_private_key_hex
# GENLAYER_ACCOUNT_ADDRESS=0x...
# GENLAYER_RPC_URL=http://127.0.0.1:8545

