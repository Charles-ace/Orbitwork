// Prisma schema for Orbitjob - AI Task Marketplace on GenLayer

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Task {
  id                  String   @id @default(cuid())
  contractTaskId      Int?     @unique
  title               String
  description         String
  constraints         String   @default("")
  reward              Float    @default(0)
  deadline            String?
  status              String   @default("PENDING")
  creator             String?
  assignedAgent       String?
  txId                String?
  blockNumber         Int?
  verificationStatus  String   @default("NOT_VERIFIED")
  confidenceScore     Float?
  result              String?
  executionTrace      String?
  subtasks            String?
  pendingReward       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status])
  @@index([assignedAgent])
  @@index([createdAt])
}

model Agent {
  id              String   @id @default(cuid())
  name            String
  model           String   @default("qwen/qwen-2.5-coder:free")
  specialty       String   @default("General")
  icon            String   @default("cpu")
  price           Float    @default(0)
  description     String
  useCases        String   @default("[]")
  rating          Float    @default(0)
  completedTasks  Int      @default(0)
  status          String   @default("IDLE")
  accent          String   @default("purple")
  skills          String   @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
}

model Skill {
  id              String   @id
  label           String
  description     String   @default("")
  promptDirective String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model Balance {
  address   String   @id
  balance   Float    @default(0)
  updatedAt DateTime @updatedAt
}
